<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>ConstructTest Pro — Construction Engineering Assessment</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css" />
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --color-background-primary: #ffffff;
    --color-background-secondary: #f5f5f3;
    --color-background-tertiary: #eeede9;
    --color-text-primary: #1a1a18;
    --color-text-secondary: #6b6b67;
    --color-border-tertiary: rgba(0,0,0,0.10);
    --color-border-secondary: rgba(0,0,0,0.18);
    --font-sans: system-ui, -apple-system, sans-serif;
    --border-radius-md: 8px;
    --border-radius-lg: 12px;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --color-background-primary: #1e1e1c;
      --color-background-secondary: #28281f;
      --color-background-tertiary: #111110;
      --color-text-primary: #f0efea;
      --color-text-secondary: #a0a09a;
      --color-border-tertiary: rgba(255,255,255,0.10);
      --color-border-secondary: rgba(255,255,255,0.18);
    }
  }

  body {
    font-family: var(--font-sans);
    background: var(--color-background-tertiary);
    color: var(--color-text-primary);
    min-height: 100vh;
  }

  .app { max-width: 800px; margin: 0 auto; background: var(--color-background-tertiary); min-height: 100vh; }

  .screen { display: none; }
  .screen.active { display: block; }

  /* ── Header ── */
  .header {
    background: var(--color-background-primary);
    border-bottom: 0.5px solid var(--color-border-tertiary);
    padding: 14px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .header-brand { display: flex; align-items: center; gap: 10px; }
  .brand-icon {
    width: 34px; height: 34px;
    background: #3B6D11;
    border-radius: var(--border-radius-md);
    display: flex; align-items: center; justify-content: center;
    color: white; font-size: 18px;
  }
  .brand-name  { font-size: 15px; font-weight: 500; color: var(--color-text-primary); }
  .brand-sub   { font-size: 12px; color: var(--color-text-secondary); }

  /* ── Buttons ── */
  .btn {
    border: 0.5px solid var(--color-border-secondary);
    background: var(--color-background-primary);
    color: var(--color-text-primary);
    border-radius: var(--border-radius-md);
    padding: 8px 16px;
    font-size: 13px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: background 0.15s;
  }
  .btn:hover  { background: var(--color-background-secondary); }
  .btn:active { transform: scale(0.98); }
  .btn-primary {
    background: #3B6D11; color: white;
    border-color: #27500A; font-weight: 500;
  }
  .btn-primary:hover { background: #27500A; }

  /* ── Badges ── */
  .badge {
    display: inline-block;
    font-size: 11px; font-weight: 500;
    padding: 3px 8px; border-radius: 99px;
  }
  .badge-green  { background: #EAF3DE; color: #3B6D11; }
  .badge-amber  { background: #FAEEDA; color: #854F0B; }
  .badge-red    { background: #FCEBEB; color: #A32D2D; }

  /* ══════════════════════════════
     LANDING
  ══════════════════════════════ */
  #landing { padding: 32px 24px; }
  .landing-hero {
    text-align: center;
    padding: 40px 24px 32px;
    max-width: 560px; margin: 0 auto;
  }
  .landing-hero h1 {
    font-size: 26px; font-weight: 500;
    color: var(--color-text-primary); margin-bottom: 10px;
  }
  .landing-hero p {
    font-size: 15px; color: var(--color-text-secondary); line-height: 1.6;
  }
  .landing-cards {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 16px; max-width: 560px; margin: 24px auto 0;
  }
  .role-card {
    cursor: pointer; padding: 24px; text-align: center;
    border: 0.5px solid var(--color-border-tertiary);
    border-radius: var(--border-radius-lg);
    background: var(--color-background-primary);
    transition: border-color 0.15s, background 0.15s;
  }
  .role-card:hover { border-color: #3B6D11; background: #EAF3DE; }
  .role-card i    { font-size: 32px; color: #3B6D11; margin-bottom: 12px; display: block; }
  .role-card h3   { font-size: 15px; font-weight: 500; color: var(--color-text-primary); margin-bottom: 6px; }
  .role-card p    { font-size: 13px; color: var(--color-text-secondary); line-height: 1.5; }

  /* ══════════════════════════════
     STUDENT SETUP
  ══════════════════════════════ */
  #student-setup { padding: 24px; }
  .setup-form { max-width: 480px; margin: 0 auto; }
  .setup-form h2 { font-size: 18px; font-weight: 500; margin-bottom: 6px; }
  .setup-form > p { font-size: 14px; color: var(--color-text-secondary); margin-bottom: 24px; }
  .form-group { margin-bottom: 16px; }
  .form-group label { display: block; font-size: 13px; color: var(--color-text-secondary); margin-bottom: 6px; }
  .form-group input,
  .form-group select {
    width: 100%; padding: 9px 12px;
    border: 0.5px solid var(--color-border-secondary);
    border-radius: var(--border-radius-md);
    background: var(--color-background-primary);
    color: var(--color-text-primary);
    font-size: 14px;
    font-family: var(--font-sans);
  }
  .topic-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
  .topic-chip {
    padding: 8px 12px;
    border: 0.5px solid var(--color-border-tertiary);
    border-radius: var(--border-radius-md);
    font-size: 13px; cursor: pointer;
    display: flex; align-items: center; gap: 8px;
    color: var(--color-text-secondary);
    transition: all 0.15s;
    user-select: none;
  }
  .topic-chip.selected {
    border-color: #3B6D11; background: #EAF3DE;
    color: #3B6D11; font-weight: 500;
  }
  .topic-chip i { font-size: 16px; }

  /* ══════════════════════════════
     LOADING
  ══════════════════════════════ */
  #loading-screen {
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    min-height: 500px; gap: 16px; padding: 24px;
  }
  .spinner {
    width: 40px; height: 40px;
    border: 3px solid var(--color-border-tertiary);
    border-top-color: #3B6D11;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  #loading-screen p { color: var(--color-text-secondary); font-size: 14px; }

  /* ══════════════════════════════
     EXAM
  ══════════════════════════════ */
  #exam-screen { padding: 0; }
  .exam-header {
    background: var(--color-background-primary);
    border-bottom: 0.5px solid var(--color-border-tertiary);
    padding: 14px 24px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .exam-meta { font-size: 13px; color: var(--color-text-secondary); }
  .exam-meta strong { color: var(--color-text-primary); }
  .progress-bar-wrap {
    background: var(--color-background-secondary);
    border-radius: 99px; height: 6px; width: 160px; overflow: hidden;
  }
  .progress-bar-fill {
    background: #3B6D11; height: 100%; border-radius: 99px; transition: width 0.3s;
  }
  .timer-display {
    font-size: 14px; font-weight: 500;
    color: var(--color-text-primary);
    display: flex; align-items: center; gap: 6px;
  }
  .timer-display.warning { color: #A32D2D; }

  .question-area {
    padding: 28px 24px; max-width: 680px; margin: 0 auto;
  }
  .q-category {
    font-size: 11px; color: #3B6D11; font-weight: 500;
    margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.06em;
  }
  .q-number { font-size: 12px; color: var(--color-text-secondary); margin-bottom: 8px; }
  .q-text {
    font-size: 16px; font-weight: 500; color: var(--color-text-primary);
    line-height: 1.6; margin-bottom: 22px;
  }
  .options { display: flex; flex-direction: column; gap: 10px; }
  .option {
    padding: 12px 16px;
    border: 0.5px solid var(--color-border-tertiary);
    border-radius: var(--border-radius-md);
    cursor: pointer; font-size: 14px;
    color: var(--color-text-primary);
    display: flex; align-items: flex-start; gap: 12px;
    line-height: 1.5; transition: all 0.15s;
  }
  .option:hover   { border-color: #3B6D11; background: #EAF3DE; }
  .option.selected{ border-color: #3B6D11; background: #EAF3DE; font-weight: 500; }
  .option.correct { border-color: #3B6D11; background: #EAF3DE; }
  .option.wrong   { border-color: #A32D2D; background: #FCEBEB; }
  .option-letter {
    width: 22px; height: 22px; border-radius: 50%;
    border: 0.5px solid var(--color-border-secondary);
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 500; flex-shrink: 0;
    background: var(--color-background-secondary); margin-top: 1px;
  }
  .option.selected .option-letter,
  .option.correct  .option-letter { background: #3B6D11; color: white; border-color: #3B6D11; }
  .option.wrong    .option-letter { background: #A32D2D; color: white; border-color: #A32D2D; }

  .explanation-box {
    margin-top: 16px; padding: 12px 14px;
    background: var(--color-background-secondary);
    border-left: 3px solid #3B6D11;
    border-radius: 0 var(--border-radius-md) var(--border-radius-md) 0;
    font-size: 13px; color: var(--color-text-secondary); line-height: 1.6;
  }

  .exam-footer {
    padding: 16px 24px;
    border-top: 0.5px solid var(--color-border-tertiary);
    display: flex; justify-content: space-between; align-items: center;
    background: var(--color-background-primary);
  }
  .q-nav { display: flex; gap: 8px; }

  /* ══════════════════════════════
     RESULTS
  ══════════════════════════════ */
  #results-screen { padding: 24px; }
  .results-wrap { max-width: 560px; margin: 0 auto; }
  .score-hero {
    text-align: center; padding: 32px 24px;
    background: var(--color-background-primary);
    border: 0.5px solid var(--color-border-tertiary);
    border-radius: var(--border-radius-lg); margin-bottom: 20px;
  }
  .score-ring {
    width: 96px; height: 96px;
    margin: 0 auto 16px; position: relative;
  }
  .score-ring svg { transform: rotate(-90deg); }
  .score-pct {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 22px; font-weight: 500; color: var(--color-text-primary);
  }
  .results-grade { font-size: 24px; font-weight: 500; margin-bottom: 6px; }
  .results-sub   { font-size: 14px; color: var(--color-text-secondary); }
  .result-stats {
    display: grid; grid-template-columns: 1fr 1fr 1fr;
    gap: 12px; margin-bottom: 20px;
  }
  .stat-card {
    background: var(--color-background-primary);
    border: 0.5px solid var(--color-border-tertiary);
    border-radius: var(--border-radius-md);
    padding: 14px; text-align: center;
  }
  .stat-num { font-size: 22px; font-weight: 500; color: var(--color-text-primary); }
  .stat-lbl { font-size: 12px; color: var(--color-text-secondary); margin-top: 4px; }
  .section-heading {
    font-size: 14px; font-weight: 500; color: var(--color-text-primary);
    margin-bottom: 12px; display: flex; align-items: center; gap: 8px;
  }
  .review-list { display: flex; flex-direction: column; gap: 10px; margin-bottom: 20px; }
  .review-item {
    padding: 12px 14px;
    background: var(--color-background-primary);
    border: 0.5px solid var(--color-border-tertiary);
    border-radius: var(--border-radius-md);
    display: flex; align-items: flex-start; gap: 10px;
  }
  .review-item.rr-correct { border-color: #97C459; }
  .review-item.rr-wrong   { border-color: #F09595; }
  .review-icon { font-size: 16px; flex-shrink: 0; margin-top: 1px; }
  .rr-correct .review-icon { color: #3B6D11; }
  .rr-wrong   .review-icon { color: #A32D2D; }
  .review-q { font-size: 13px; color: var(--color-text-primary); margin-bottom: 3px; }
  .review-a { font-size: 12px; color: var(--color-text-secondary); }
  .results-actions { display: flex; gap: 12px; flex-wrap: wrap; }

  /* ══════════════════════════════
     ADMIN
  ══════════════════════════════ */
  #admin-screen { padding: 0; }
  .admin-nav {
    display: flex; border-bottom: 0.5px solid var(--color-border-tertiary);
    padding: 0 24px; gap: 2px;
    background: var(--color-background-primary);
    overflow-x: auto;
  }
  .admin-tab {
    padding: 12px 16px; font-size: 13px;
    color: var(--color-text-secondary); cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -0.5px;
    display: flex; align-items: center; gap: 6px;
    white-space: nowrap;
  }
  .admin-tab.active { color: #3B6D11; border-bottom-color: #3B6D11; font-weight: 500; }
  .admin-content { padding: 20px 24px; }

  .admin-overview {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 12px; margin-bottom: 20px;
  }
  @media (max-width: 600px) { .admin-overview { grid-template-columns: 1fr 1fr; } }

  .student-table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .student-table th {
    text-align: left; padding: 10px 12px;
    color: var(--color-text-secondary); font-weight: 500;
    border-bottom: 0.5px solid var(--color-border-tertiary);
    font-size: 12px; white-space: nowrap;
  }
  .student-table td {
    padding: 10px 12px;
    border-bottom: 0.5px solid var(--color-border-tertiary);
    color: var(--color-text-primary); vertical-align: middle;
  }
  .student-table tr:last-child td { border-bottom: none; }
  .mini-bar-wrap {
    background: var(--color-border-tertiary);
    border-radius: 99px; height: 4px; width: 80px; overflow: hidden;
  }
  .mini-bar-fill       { height: 100%; border-radius: 99px; background: #3B6D11; }
  .mini-bar-fill.ok    { background: #854F0B; }
  .mini-bar-fill.bad   { background: #A32D2D; }

  .topic-perf { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 20px; }
  @media (max-width: 500px) { .topic-perf { grid-template-columns: 1fr; } }
  .topic-perf-item {
    padding: 12px 14px;
    background: var(--color-background-primary);
    border: 0.5px solid var(--color-border-tertiary);
    border-radius: var(--border-radius-md);
  }
  .topic-perf-label {
    font-size: 13px; color: var(--color-text-primary);
    margin-bottom: 8px; display: flex; align-items: center; gap: 6px;
  }
  .topic-perf-label i { font-size: 15px; color: #3B6D11; }
  .topic-bar-wrap {
    background: var(--color-background-secondary);
    border-radius: 99px; height: 5px; overflow: hidden; margin-bottom: 4px;
  }
  .topic-bar-fill { height: 100%; border-radius: 99px; background: #3B6D11; }
  .topic-pct { font-size: 11px; color: var(--color-text-secondary); }

  .detail-panel { display: none; }
  .detail-panel.open { display: block; }
  .detail-header {
    display: flex; align-items: center; gap: 12px;
    padding: 14px 0; border-bottom: 0.5px solid var(--color-border-tertiary);
    margin-bottom: 16px;
  }
  .attempt-list { display: flex; flex-direction: column; gap: 10px; }
  .attempt-card {
    padding: 14px;
    background: var(--color-background-primary);
    border: 0.5px solid var(--color-border-tertiary);
    border-radius: var(--border-radius-md);
    display: flex; justify-content: space-between; align-items: center;
    gap: 12px;
  }
  .attempt-card-left h4 { font-size: 14px; font-weight: 500; margin-bottom: 4px; }
  .attempt-card-left p  { font-size: 12px; color: var(--color-text-secondary); }
  .table-wrap {
    background: var(--color-background-primary);
    border: 0.5px solid var(--color-border-tertiary);
    border-radius: var(--border-radius-lg);
    overflow: hidden; overflow-x: auto;
  }
</style>
</head>
<body>
<div class="app" id="app">

  <!-- ── Global Header ── -->
  <div class="header">
    <div class="header-brand">
      <div class="brand-icon"><i class="ti ti-building" aria-hidden="true"></i></div>
      <div>
        <div class="brand-name">ConstructTest Pro</div>
        <div class="brand-sub">Construction Engineering Assessment</div>
      </div>
    </div>
    <div id="header-actions"></div>
  </div>

  <!-- ══════════════════════════════
       LANDING
  ══════════════════════════════ -->
  <div id="landing" class="screen active">
    <div class="landing-hero">
      <h1>Construction Engineering Exam</h1>
      <p>AI-generated questions across structural, safety, materials, and project management topics. Each exam session is unique.</p>
    </div>
    <div class="landing-cards">
      <div class="role-card" onclick="goStudentSetup()">
        <i class="ti ti-pencil" aria-hidden="true"></i>
        <h3>Take the exam</h3>
        <p>Start a new assessment with fresh AI-generated questions</p>
      </div>
      <div class="role-card" onclick="goAdmin()">
        <i class="ti ti-chart-bar" aria-hidden="true"></i>
        <h3>Admin dashboard</h3>
        <p>View student progress, scores, and topic performance</p>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════
       STUDENT SETUP
  ══════════════════════════════ -->
  <div id="student-setup" class="screen">
    <div class="setup-form">
      <h2>Start your exam</h2>
      <p>Fill in your details and choose your exam focus areas.</p>

      <div class="form-group">
        <label>Full name</label>
        <input type="text" id="student-name" placeholder="e.g. Ahmed Raza" />
      </div>
      <div class="form-group">
        <label>Years of experience</label>
        <select id="student-exp">
          <option>0–2 years (Junior)</option>
          <option>3–5 years (Mid-level)</option>
          <option>6–10 years (Senior)</option>
          <option>10+ years (Expert)</option>
        </select>
      </div>
      <div class="form-group">
        <label>Number of questions</label>
        <select id="q-count">
          <option value="5">5 questions (Quick)</option>
          <option value="10" selected>10 questions (Standard)</option>
          <option value="15">15 questions (Full)</option>
        </select>
      </div>
      <div class="form-group">
        <label>Topics (select at least one)</label>
        <div class="topic-grid" id="topic-grid">
          <div class="topic-chip selected" data-topic="Structural Engineering"    onclick="toggleTopic(this)"><i class="ti ti-building-arch" aria-hidden="true"></i> Structural</div>
          <div class="topic-chip selected" data-topic="Safety & Regulations"      onclick="toggleTopic(this)"><i class="ti ti-shield-check"  aria-hidden="true"></i> Safety & Regulations</div>
          <div class="topic-chip selected" data-topic="Materials Science"          onclick="toggleTopic(this)"><i class="ti ti-cube"          aria-hidden="true"></i> Materials Science</div>
          <div class="topic-chip"          data-topic="Project Management"         onclick="toggleTopic(this)"><i class="ti ti-clipboard-list"aria-hidden="true"></i> Project Management</div>
          <div class="topic-chip"          data-topic="Geotechnical Engineering"   onclick="toggleTopic(this)"><i class="ti ti-layers"        aria-hidden="true"></i> Geotechnical</div>
          <div class="topic-chip"          data-topic="MEP Systems"                onclick="toggleTopic(this)"><i class="ti ti-tool"          aria-hidden="true"></i> MEP Systems</div>
        </div>
      </div>

      <div style="display:flex; gap:10px; margin-top:24px;">
        <button class="btn" onclick="goLanding()"><i class="ti ti-arrow-left" aria-hidden="true"></i> Back</button>
        <button class="btn btn-primary" onclick="startExam()"><i class="ti ti-player-play" aria-hidden="true"></i> Generate exam</button>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════
       LOADING
  ══════════════════════════════ -->
  <div id="loading-screen" class="screen">
    <div class="spinner"></div>
    <p id="loading-text">Generating your personalized exam questions…</p>
  </div>

  <!-- ══════════════════════════════
       EXAM
  ══════════════════════════════ -->
  <div id="exam-screen" class="screen">
    <div class="exam-header">
      <div class="exam-meta">
        <strong id="exam-q-label">Question 1</strong> of <span id="exam-total">10</span>
      </div>
      <div style="display:flex; align-items:center; gap:16px;">
        <div class="progress-bar-wrap">
          <div class="progress-bar-fill" id="exam-progress"></div>
        </div>
        <div class="timer-display" id="timer-display">
          <i class="ti ti-clock" aria-hidden="true"></i>
          <span id="timer-text">0:00</span>
        </div>
      </div>
    </div>

    <div class="question-area">
      <div class="q-category" id="q-category"></div>
      <div class="q-number"   id="q-number"></div>
      <div class="q-text"     id="q-text"></div>
      <div class="options"    id="q-options"></div>
      <div class="explanation-box" id="explanation-box" style="display:none;"></div>
    </div>

    <div class="exam-footer">
      <div class="q-nav">
        <button class="btn" id="btn-prev" onclick="prevQ()"><i class="ti ti-arrow-left" aria-hidden="true"></i> Prev</button>
        <button class="btn" id="btn-next" onclick="nextQ()">Next <i class="ti ti-arrow-right" aria-hidden="true"></i></button>
      </div>
      <button class="btn btn-primary" id="btn-submit" onclick="submitExam()" style="display:none;">
        Submit exam <i class="ti ti-check" aria-hidden="true"></i>
      </button>
    </div>
  </div>

  <!-- ══════════════════════════════
       RESULTS
  ══════════════════════════════ -->
  <div id="results-screen" class="screen">
    <div class="results-wrap">
      <div class="score-hero">
        <div class="score-ring">
          <svg width="96" height="96" viewBox="0 0 96 96">
            <circle cx="48" cy="48" r="40" fill="none" stroke="#e5e5e3" stroke-width="8"/>
            <circle cx="48" cy="48" r="40" fill="none" stroke="#3B6D11" stroke-width="8"
              stroke-linecap="round" id="score-arc"
              stroke-dasharray="251.2" stroke-dashoffset="251.2"
              style="transition: stroke-dashoffset 0.8s ease;"/>
          </svg>
          <div class="score-pct" id="score-pct">0%</div>
        </div>
        <div class="results-grade" id="results-grade"></div>
        <div class="results-sub"   id="results-sub"></div>
      </div>

      <div class="result-stats">
        <div class="stat-card"><div class="stat-num" id="stat-correct">0</div><div class="stat-lbl">Correct</div></div>
        <div class="stat-card"><div class="stat-num" id="stat-wrong">0</div><div class="stat-lbl">Incorrect</div></div>
        <div class="stat-card"><div class="stat-num" id="stat-time">0m</div><div class="stat-lbl">Time taken</div></div>
      </div>

      <div class="section-heading"><i class="ti ti-list" aria-hidden="true"></i> Question review</div>
      <div class="review-list" id="review-list"></div>

      <div class="results-actions">
        <button class="btn btn-primary" onclick="retakeExam()"><i class="ti ti-refresh" aria-hidden="true"></i> Retake with new questions</button>
        <button class="btn" onclick="goLanding()"><i class="ti ti-home" aria-hidden="true"></i> Home</button>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════
       ADMIN DASHBOARD
  ══════════════════════════════ -->
  <div id="admin-screen" class="screen">
    <div class="admin-nav">
      <div class="admin-tab active" data-tab="overview" onclick="switchAdminTab('overview', this)">
        <i class="ti ti-dashboard" aria-hidden="true"></i> Overview
      </div>
      <div class="admin-tab" data-tab="students" onclick="switchAdminTab('students', this)">
        <i class="ti ti-users" aria-hidden="true"></i> Students
      </div>
      <div class="admin-tab" data-tab="topics" onclick="switchAdminTab('topics', this)">
        <i class="ti ti-chart-pie" aria-hidden="true"></i> Topic performance
      </div>
    </div>

    <div class="admin-content">

      <!-- Overview tab -->
      <div id="tab-overview">
        <div class="admin-overview" id="admin-stats-grid"></div>
        <div class="section-heading"><i class="ti ti-history" aria-hidden="true"></i> Recent exam attempts</div>
        <div class="table-wrap">
          <table class="student-table">
            <thead><tr>
              <th>Student</th><th>Score</th><th>Topics</th><th>Time</th><th>Result</th>
            </tr></thead>
            <tbody id="recent-tbody"></tbody>
          </table>
        </div>
      </div>

      <!-- Students tab -->
      <div id="tab-students" style="display:none;">
        <div class="section-heading"><i class="ti ti-users" aria-hidden="true"></i> All students</div>
        <div class="table-wrap" style="margin-bottom:16px;">
          <table class="student-table">
            <thead><tr>
              <th>Name</th><th>Attempts</th><th>Best</th><th>Avg</th><th>Last attempt</th><th></th>
            </tr></thead>
            <tbody id="students-tbody"></tbody>
          </table>
        </div>
        <div class="detail-panel" id="student-detail">
          <div class="detail-header">
            <button class="btn" onclick="closeDetail()"><i class="ti ti-arrow-left" aria-hidden="true"></i></button>
            <div>
              <div style="font-size:15px;font-weight:500;" id="detail-name"></div>
              <div style="font-size:12px;color:var(--color-text-secondary);" id="detail-sub"></div>
            </div>
          </div>
          <div class="section-heading">All attempts</div>
          <div class="attempt-list" id="attempt-list"></div>
        </div>
      </div>

      <!-- Topics tab -->
      <div id="tab-topics" style="display:none;">
        <div class="section-heading"><i class="ti ti-chart-pie" aria-hidden="true"></i> Average score by topic</div>
        <div class="topic-perf" id="topic-perf-grid"></div>
        <div class="section-heading"><i class="ti ti-alert-triangle" aria-hidden="true"></i> Areas needing attention</div>
        <div id="weak-topics"></div>
      </div>

    </div>
  </div>

</div><!-- /.app -->

<script>
/* ═══════════════════════════════════════════════
   CONFIG — replace with your Anthropic API key
   when running locally (not needed on claude.ai)
═══════════════════════════════════════════════ */
const ANTHROPIC_API_KEY = ""; // Leave blank on claude.ai; fill in for local use
const API_URL = "https://api.anthropic.com/v1/messages";
const STORAGE_KEY = "constructtest_records";

/* ═══════════════════════════════════════════════
   STATE
═══════════════════════════════════════════════ */
let state = {
  studentName: "",
  studentExp: "",
  questions: [],
  answers: {},
  currentQ: 0,
  startTime: null,
  endTime: null,
  selectedTopics: [],
  qCount: 10
};

/* ═══════════════════════════════════════════════
   STORAGE (localStorage)
═══════════════════════════════════════════════ */
function loadRecords() {
  try {
    const r = localStorage.getItem(STORAGE_KEY);
    return r ? JSON.parse(r) : [];
  } catch { return []; }
}

function saveRecord(rec) {
  const records = loadRecords();
  records.push(rec);
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(records)); } catch (e) {
    console.warn("localStorage full, trimming oldest records.");
    records.shift();
    localStorage.setItem(STORAGE_KEY, JSON.stringify(records));
  }
}

/* ═══════════════════════════════════════════════
   NAVIGATION
═══════════════════════════════════════════════ */
function show(id) {
  document.querySelectorAll(".screen").forEach(s => s.classList.remove("active"));
  document.getElementById(id).classList.add("active");
  window.scrollTo(0, 0);
}

function setHeaderActions(html) {
  document.getElementById("header-actions").innerHTML = html;
}

function goLanding() {
  setHeaderActions("");
  show("landing");
}

function goStudentSetup() {
  setHeaderActions('<button class="btn" onclick="goLanding()"><i class="ti ti-arrow-left" aria-hidden="true"></i> Back</button>');
  show("student-setup");
}

function goAdmin() {
  setHeaderActions('<button class="btn" onclick="goLanding()"><i class="ti ti-home" aria-hidden="true"></i> Home</button>');
  show("admin-screen");
  renderAdmin();
}

/* ═══════════════════════════════════════════════
   TOPIC CHIPS
═══════════════════════════════════════════════ */
function toggleTopic(el) {
  el.classList.toggle("selected");
}

/* ═══════════════════════════════════════════════
   START EXAM — calls Anthropic API
═══════════════════════════════════════════════ */
async function startExam() {
  const name = document.getElementById("student-name").value.trim();
  if (!name) { alert("Please enter your name."); return; }

  const topics = [...document.querySelectorAll(".topic-chip.selected")].map(c => c.dataset.topic);
  if (!topics.length) { alert("Please select at least one topic."); return; }

  state.studentName   = name;
  state.studentExp    = document.getElementById("student-exp").value;
  state.selectedTopics = topics;
  state.qCount        = parseInt(document.getElementById("q-count").value);
  state.answers       = {};
  state.currentQ      = 0;
  state.questions     = [];

  show("loading-screen");

  const loadingMsgs = [
    "Generating your personalized exam questions…",
    "Consulting construction codes and standards…",
    "Calibrating difficulty to your experience level…",
    "Almost ready…"
  ];
  let mi = 0;
  const loadInterval = setInterval(() => {
    mi = (mi + 1) % loadingMsgs.length;
    const el = document.getElementById("loading-text");
    if (el) el.textContent = loadingMsgs[mi];
  }, 2200);

  const prompt = `Generate exactly ${state.qCount} multiple-choice questions for a construction engineering professional exam.

Student experience level: ${state.studentExp}
Topics to cover (distribute questions evenly): ${topics.join(", ")}

Requirements:
- Each question must be technical, realistic, and appropriate for professional construction engineers
- Mix of difficulty: some straightforward recall, some scenario-based application questions
- All correct answers must be unambiguous and definitively correct
- Options should be plausible (not obviously wrong distractors)
- Cover real-world codes, standards, and best practices (ACI, OSHA, AISC, BS, IS codes etc. as relevant)

Respond ONLY with a valid JSON array. No markdown fences, no explanations, just raw JSON. Format:
[
  {
    "category": "Structural Engineering",
    "question": "Full question text here",
    "options": ["Option A", "Option B", "Option C", "Option D"],
    "correct": 2,
    "explanation": "Why this answer is correct, referencing the relevant standard or principle."
  }
]

The "correct" field is a 0-based index into the options array.
Return exactly ${state.qCount} questions.`;

  try {
    const headers = { "Content-Type": "application/json" };
    if (ANTHROPIC_API_KEY) headers["x-api-key"] = ANTHROPIC_API_KEY;

    const res = await fetch(API_URL, {
      method: "POST",
      headers,
      body: JSON.stringify({
        model: "claude-sonnet-4-6",
        max_tokens: 4000,
        messages: [{ role: "user", content: prompt }]
      })
    });

    clearInterval(loadInterval);

    if (!res.ok) {
      const err = await res.json().catch(() => ({}));
      throw new Error(err.error?.message || "API error " + res.status);
    }

    const data = await res.json();
    let raw = data.content.map(b => b.text || "").join("");

    // Strip any accidental markdown fences
    raw = raw.replace(/```json|```/g, "").trim();
    const first = raw.indexOf("[");
    const last  = raw.lastIndexOf("]");
    if (first === -1 || last === -1) throw new Error("No JSON array found in response.");
    raw = raw.slice(first, last + 1);

    state.questions = JSON.parse(raw);
    if (!Array.isArray(state.questions) || !state.questions.length) {
      throw new Error("Parsed questions array is empty.");
    }

    state.startTime = Date.now();
    renderExam();
    show("exam-screen");
    setHeaderActions('<button class="btn" onclick="if(confirm(\'Exit exam? Progress will be lost.\')) goLanding()"><i class="ti ti-x" aria-hidden="true"></i> Exit</button>');
    startTimer();

  } catch (e) {
    clearInterval(loadInterval);
    console.error(e);
    alert("Could not generate exam questions.\n\nError: " + e.message + "\n\nMake sure your API key is set correctly (ANTHROPIC_API_KEY in the script) when running locally.");
    show("student-setup");
  }
}

/* ═══════════════════════════════════════════════
   TIMER
═══════════════════════════════════════════════ */
let timerInterval = null;

function startTimer() {
  if (timerInterval) clearInterval(timerInterval);
  timerInterval = setInterval(() => {
    const elapsed = Math.floor((Date.now() - state.startTime) / 1000);
    const m = Math.floor(elapsed / 60);
    const s = elapsed % 60;
    const el = document.getElementById("timer-text");
    if (el) el.textContent = m + ":" + String(s).padStart(2, "0");
    const td = document.getElementById("timer-display");
    if (td) td.classList.toggle("warning", elapsed > 1800);
  }, 1000);
}

/* ═══════════════════════════════════════════════
   EXAM RENDER
═══════════════════════════════════════════════ */
function renderExam() {
  const q     = state.questions[state.currentQ];
  const total = state.questions.length;
  const answered = state.answers[state.currentQ] !== undefined;
  const chosen   = state.answers[state.currentQ];

  document.getElementById("exam-q-label").textContent = "Question " + (state.currentQ + 1);
  document.getElementById("exam-total").textContent   = total;
  document.getElementById("exam-progress").style.width = (((state.currentQ) / total) * 100) + "%";
  document.getElementById("q-category").textContent   = q.category;
  document.getElementById("q-number").textContent     = "Q" + (state.currentQ + 1) + " of " + total;
  document.getElementById("q-text").textContent       = q.question;

  const letters  = ["A", "B", "C", "D", "E"];
  const optEl    = document.getElementById("q-options");
  optEl.innerHTML = q.options.map((opt, i) => {
    let cls = "option";
    if (answered) {
      if (i === q.correct)                    cls += " correct";
      else if (i === chosen && i !== q.correct) cls += " wrong";
    } else if (i === chosen) {
      cls += " selected";
    }
    const click = answered ? "" : `onclick="selectAnswer(${i})"`;
    return `<div class="${cls}" ${click}>
      <span class="option-letter">${letters[i]}</span>
      <span>${opt}</span>
    </div>`;
  }).join("");

  const expEl = document.getElementById("explanation-box");
  if (answered && q.explanation) {
    expEl.textContent = "💡 " + q.explanation;
    expEl.style.display = "block";
  } else {
    expEl.style.display = "none";
  }

  document.getElementById("btn-prev").style.visibility =
    state.currentQ === 0 ? "hidden" : "visible";
  document.getElementById("btn-next").style.display =
    state.currentQ < total - 1 ? "inline-flex" : "none";
  document.getElementById("btn-submit").style.display =
    state.currentQ === total - 1 ? "inline-flex" : "none";
}

function selectAnswer(i) {
  state.answers[state.currentQ] = i;
  renderExam();
}

function prevQ() {
  if (state.currentQ > 0) { state.currentQ--; renderExam(); }
}

function nextQ() {
  if (state.currentQ < state.questions.length - 1) { state.currentQ++; renderExam(); }
}

/* ═══════════════════════════════════════════════
   SUBMIT EXAM
═══════════════════════════════════════════════ */
function submitExam() {
  if (timerInterval) clearInterval(timerInterval);
  state.endTime = Date.now();

  const timeSec = Math.floor((state.endTime - state.startTime) / 1000);
  const total   = state.questions.length;
  let correct   = 0;
  state.questions.forEach((q, i) => {
    if (state.answers[i] === q.correct) correct++;
  });

  const pct = Math.round((correct / total) * 100);
  let grade = "Fail";
  if      (pct >= 90) grade = "Distinction";
  else if (pct >= 75) grade = "Pass";
  else if (pct >= 60) grade = "Marginal pass";

  // Save to localStorage
  const record = {
    id:          Date.now(),
    name:        state.studentName,
    exp:         state.studentExp,
    topics:      state.selectedTopics,
    score:       pct,
    correct,
    total,
    timeSec,
    grade,
    date:        new Date().toISOString(),
    questionData: state.questions.map((q, i) => ({
      category:      q.category,
      question:      q.question,
      correct:       state.answers[i] === q.correct,
      chosen:        q.options[state.answers[i]] || "Not answered",
      correctAnswer: q.options[q.correct]
    }))
  };
  saveRecord(record);

  // Render results
  document.getElementById("score-pct").textContent = pct + "%";
  setTimeout(() => {
    document.getElementById("score-arc").style.strokeDashoffset =
      (251.2 * (1 - pct / 100)).toFixed(2);
  }, 100);
  document.getElementById("results-grade").textContent = grade;
  document.getElementById("results-sub").textContent   = correct + " of " + total + " questions correct";
  document.getElementById("stat-correct").textContent  = correct;
  document.getElementById("stat-wrong").textContent    = total - correct;
  const m = Math.floor(timeSec / 60), s = timeSec % 60;
  document.getElementById("stat-time").textContent = m + "m " + s + "s";

  const revList = document.getElementById("review-list");
  revList.innerHTML = state.questions.map((q, i) => {
    const ok = state.answers[i] === q.correct;
    return `<div class="review-item ${ok ? "rr-correct" : "rr-wrong"}">
      <i class="ti ${ok ? "ti-check" : "ti-x"} review-icon" aria-hidden="true"></i>
      <div>
        <div class="review-q">${q.question}</div>
        <div class="review-a">${ok
          ? "Correct: " + q.options[q.correct]
          : "Your answer: " + (q.options[state.answers[i]] || "Not answered") + " · Correct: " + q.options[q.correct]
        }</div>
      </div>
    </div>`;
  }).join("");

  setHeaderActions('<button class="btn" onclick="goLanding()"><i class="ti ti-home" aria-hidden="true"></i> Home</button>');
  show("results-screen");
}

function retakeExam() {
  // Pre-fill name, then auto-start
  document.getElementById("student-name").value = state.studentName;
  goStudentSetup();
}

/* ═══════════════════════════════════════════════
   ADMIN DASHBOARD
═══════════════════════════════════════════════ */
function renderAdmin() {
  const records = loadRecords();
  const total   = records.length;
  const avgScore = total
    ? Math.round(records.reduce((a, r) => a + r.score, 0) / total)
    : 0;
  const passed   = records.filter(r => r.score >= 60).length;
  const students = [...new Set(records.map(r => r.name))];

  // ── Stat cards ──
  const statsGrid = document.getElementById("admin-stats-grid");
  statsGrid.innerHTML = [
    ["ti-users",        "Total students", students.length],
    ["ti-file-text",    "Total exams",    total],
    ["ti-chart-line",   "Average score",  avgScore + "%"],
    ["ti-check-circle", "Pass rate",      total ? Math.round(passed / total * 100) + "%" : "—"]
  ].map(([icon, label, val]) => `
    <div class="stat-card">
      <div style="font-size:20px;color:#3B6D11;margin-bottom:8px;"><i class="ti ${icon}" aria-hidden="true"></i></div>
      <div class="stat-num">${val}</div>
      <div class="stat-lbl">${label}</div>
    </div>`).join("");

  // ── Recent attempts ──
  const tbody = document.getElementById("recent-tbody");
  if (!records.length) {
    tbody.innerHTML = `<tr><td colspan="5" style="text-align:center;padding:28px;color:var(--color-text-secondary);font-size:13px;">
      No exam attempts yet. Students can start from the home screen.
    </td></tr>`;
  } else {
    tbody.innerHTML = [...records].reverse().slice(0, 10).map(r => {
      const scoreColor = r.score >= 75 ? "#3B6D11" : r.score >= 60 ? "#854F0B" : "#A32D2D";
      const barCls     = r.score >= 75 ? ""        : r.score >= 60 ? "ok"       : "bad";
      const d          = new Date(r.date).toLocaleDateString("en-GB", { day:"2-digit", month:"short", year:"numeric" });
      const topicStr   = (r.topics || []).slice(0, 2).join(", ") + ((r.topics || []).length > 2 ? "…" : "");
      return `<tr>
        <td>
          <strong style="font-size:13px;">${r.name}</strong><br>
          <span style="font-size:11px;color:var(--color-text-secondary);">${r.exp || ""}</span>
        </td>
        <td>
          <span style="font-weight:500;color:${scoreColor};">${r.score}%</span>
          <div class="mini-bar-wrap" style="margin-top:4px;">
            <div class="mini-bar-fill ${barCls}" style="width:${r.score}%"></div>
          </div>
        </td>
        <td style="font-size:12px;color:var(--color-text-secondary);">${topicStr || "—"}</td>
        <td style="font-size:12px;">${Math.floor(r.timeSec / 60)}m ${r.timeSec % 60}s</td>
        <td><span class="badge ${r.score >= 75 ? "badge-green" : r.score >= 60 ? "badge-amber" : "badge-red"}">${r.grade || (r.score >= 60 ? "Pass" : "Fail")}</span></td>
      </tr>`;
    }).join("");
  }

  renderStudentsTab(records);
  renderTopicsTab(records);
}

/* ── Students tab ── */
function renderStudentsTab(records) {
  const byStudent = {};
  records.forEach(r => {
    if (!byStudent[r.name]) byStudent[r.name] = [];
    byStudent[r.name].push(r);
  });

  const tbody = document.getElementById("students-tbody");
  if (!Object.keys(byStudent).length) {
    tbody.innerHTML = `<tr><td colspan="6" style="text-align:center;padding:28px;color:var(--color-text-secondary);font-size:13px;">No students yet.</td></tr>`;
    return;
  }

  tbody.innerHTML = Object.entries(byStudent).map(([name, recs]) => {
    const best  = Math.max(...recs.map(r => r.score));
    const avg   = Math.round(recs.reduce((a, r) => a + r.score, 0) / recs.length);
    const last  = new Date(Math.max(...recs.map(r => new Date(r.date).getTime())))
                    .toLocaleDateString("en-GB", { day:"2-digit", month:"short" });
    const col   = best >= 75 ? "#3B6D11" : best >= 60 ? "#854F0B" : "#A32D2D";
    const safeN = name.replace(/"/g, "&quot;");
    return `<tr>
      <td><strong style="font-size:13px;">${name}</strong></td>
      <td>${recs.length}</td>
      <td><span style="color:${col};font-weight:500;">${best}%</span></td>
      <td>${avg}%</td>
      <td style="font-size:12px;color:var(--color-text-secondary);">${last}</td>
      <td><button class="btn" style="padding:5px 10px;font-size:12px;" onclick='viewStudentDetail("${safeN}")'>
        View <i class="ti ti-chevron-right" aria-hidden="true"></i>
      </button></td>
    </tr>`;
  }).join("");
}

function viewStudentDetail(name) {
  const records = loadRecords().filter(r => r.name === name);
  document.getElementById("student-detail").classList.add("open");
  document.getElementById("detail-name").textContent = name;
  document.getElementById("detail-sub").textContent  = records[0]?.exp || "";

  const list = document.getElementById("attempt-list");
  list.innerHTML = [...records].reverse().map(r => {
    const d = new Date(r.date).toLocaleString("en-GB", {
      day:"2-digit", month:"short", year:"numeric", hour:"2-digit", minute:"2-digit"
    });
    const badgeCls = r.score >= 75 ? "badge-green" : r.score >= 60 ? "badge-amber" : "badge-red";
    return `<div class="attempt-card">
      <div class="attempt-card-left">
        <h4>${r.score}% — ${r.grade || (r.score >= 60 ? "Pass" : "Fail")}</h4>
        <p>${r.correct}/${r.total} correct · ${Math.floor(r.timeSec / 60)}m ${r.timeSec % 60}s · ${d}</p>
        <p style="margin-top:4px;">${(r.topics || []).join(", ")}</p>
      </div>
      <span class="badge ${badgeCls}">${r.score >= 75 ? "Pass" : r.score >= 60 ? "Marginal" : "Fail"}</span>
    </div>`;
  }).join("");
}

function closeDetail() {
  document.getElementById("student-detail").classList.remove("open");
}

/* ── Topics tab ── */
function renderTopicsTab(records) {
  const topicScores = {};

  records.forEach(r => {
    // Use per-question data if available (more accurate)
    if (r.questionData && r.questionData.length) {
      const byCat = {};
      r.questionData.forEach(qd => {
        if (!byCat[qd.category]) byCat[qd.category] = { correct: 0, total: 0 };
        byCat[qd.category].total++;
        if (qd.correct) byCat[qd.category].correct++;
      });
      Object.entries(byCat).forEach(([cat, v]) => {
        if (!topicScores[cat]) topicScores[cat] = [];
        topicScores[cat].push(Math.round(v.correct / v.total * 100));
      });
    } else {
      // Fallback: attribute overall score to each selected topic
      (r.topics || []).forEach(t => {
        if (!topicScores[t]) topicScores[t] = [];
        topicScores[t].push(r.score);
      });
    }
  });

  const icons = {
    "Structural Engineering":  "ti-building-arch",
    "Safety & Regulations":    "ti-shield-check",
    "Materials Science":       "ti-cube",
    "Project Management":      "ti-clipboard-list",
    "Geotechnical Engineering":"ti-layers",
    "MEP Systems":             "ti-tool"
  };

  const entries = Object.entries(topicScores)
    .map(([topic, scores]) => ({
      topic,
      avg: Math.round(scores.reduce((a, s) => a + s, 0) / scores.length)
    }))
    .sort((a, b) => b.avg - a.avg);

  const grid = document.getElementById("topic-perf-grid");
  if (!entries.length) {
    grid.innerHTML = '<div style="color:var(--color-text-secondary);font-size:13px;padding:16px 0;">No data yet. Complete at least one exam to see topic performance.</div>';
    document.getElementById("weak-topics").innerHTML = "";
    return;
  }

  grid.innerHTML = entries.map(({ topic, avg }) => {
    const ic  = icons[topic] || "ti-tool";
    const col = avg >= 75 ? "#3B6D11" : avg >= 60 ? "#854F0B" : "#A32D2D";
    return `<div class="topic-perf-item">
      <div class="topic-perf-label"><i class="ti ${ic}" aria-hidden="true"></i> ${topic}</div>
      <div class="topic-bar-wrap">
        <div class="topic-bar-fill" style="width:${avg}%;background:${col};"></div>
      </div>
      <div class="topic-pct">${avg}% average</div>
    </div>`;
  }).join("");

  const weak    = entries.filter(e => e.avg < 65);
  const weakEl  = document.getElementById("weak-topics");
  if (!weak.length) {
    weakEl.innerHTML = `<div style="font-size:13px;color:#3B6D11;padding:12px;background:#EAF3DE;border-radius:var(--border-radius-md);">
      ✓ All topics performing well across all students.
    </div>`;
  } else {
    weakEl.innerHTML = weak.map(e => `
      <div style="padding:12px;background:#FAEEDA;border-radius:var(--border-radius-md);margin-bottom:8px;font-size:13px;color:#854F0B;">
        <strong>${e.topic}</strong> — ${e.avg}% average score.
        Consider providing additional study materials or revision sessions for this topic.
      </div>`).join("");
  }
}

/* ── Admin tab switching ── */
function switchAdminTab(tab, el) {
  document.querySelectorAll(".admin-tab").forEach(t => t.classList.remove("active"));
  el.classList.add("active");
  document.getElementById("tab-overview").style.display  = tab === "overview"  ? "" : "none";
  document.getElementById("tab-students").style.display  = tab === "students"  ? "" : "none";
  document.getElementById("tab-topics").style.display    = tab === "topics"    ? "" : "none";
}
</script>
</body>
</html>
