<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Site Readiness — Engineer Skills Evaluation</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;600;700;800&family=Archivo+Expanded:wght@600;700&family=Source+Serif+4:ital,wght@0,400;0,500;0,600;1,400&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --paper:#F4F1E9;
    --paper-deep:#ECE7DA;
    --ink:#0F1714;
    --ink-soft:#1C2622;
    --steel:#5B6B63;
    --steel-pale:#8A968F;
    --rust:#B8501F;
    --rust-deep:#8F3D17;
    --pine:#1E3A34;
    --pine-pale:#E4ECE8;
    --oxide:#7A2A1C;
    --oxide-pale:#F3E2DC;
    --gold:#9A7421;
    --gold-pale:#F1E8D2;
    --line:#C7BFA9;
    --line-soft:#DCD6C4;
    --card:#FBF9F3;

    --display:'Archivo Expanded', 'Archivo', sans-serif;
    --grotesk:'Archivo', sans-serif;
    --serif:'Source Serif 4', Georgia, serif;
    --mono:'IBM Plex Mono', 'Courier New', monospace;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    background:var(--paper);
    color:var(--ink);
    font-family:var(--grotesk);
    min-height:100vh;
    -webkit-font-smoothing:antialiased;
  }
  body::before{
    content:"";
    position:fixed;inset:0;pointer-events:none;z-index:0;
    background-image:
      repeating-linear-gradient(0deg, transparent 0 39px, rgba(15,23,20,0.035) 39px 40px),
      repeating-linear-gradient(90deg, transparent 0 39px, rgba(15,23,20,0.035) 39px 40px);
    opacity:0.6;
  }
  ::selection{background:var(--rust);color:var(--paper);}

  .app{position:relative;z-index:1;max-width:1080px;margin:0 auto;padding:32px 22px 90px;}

  /* dimension-line divider: tick - line - tick, like a drawing dimension */
  .dimline{
    display:flex;align-items:center;gap:8px;margin:26px 0;
    color:var(--steel-pale);
  }
  .dimline::before, .dimline::after{
    content:"";flex:1;height:1px;background:var(--line);
    background-image:linear-gradient(90deg, var(--line) 0, var(--line) 6px, transparent 6px, transparent 7px);
    background-size:7px 1px;
  }
  .dimline span{font-family:var(--mono);font-size:10px;letter-spacing:2px;text-transform:uppercase;white-space:nowrap;}

  /* ================= TITLE BLOCK (masthead) ================= */
  .titleblock{
    border:1.5px solid var(--ink);
    background:var(--card);
    display:grid;
    grid-template-columns:1fr auto;
    margin-bottom:4px;
  }
  .tb-main{
    padding:20px 24px 18px;
    border-right:1.5px solid var(--ink);
  }
  .tb-eyebrow{
    font-family:var(--mono);font-size:10px;letter-spacing:3px;text-transform:uppercase;
    color:var(--rust-deep);margin-bottom:6px;
  }
  .tb-title{
    font-family:var(--display);font-weight:700;font-size:26px;letter-spacing:0.5px;
    margin:0;line-height:1.05;color:var(--ink);
  }
  .tb-cells{
    display:flex;flex-direction:column;
  }
  .tb-cell{
    padding:10px 18px;border-bottom:1.5px solid var(--ink);
    display:flex;flex-direction:column;gap:2px;min-width:170px;
  }
  .tb-cell:last-child{border-bottom:none;}
  .tb-cell .k{font-family:var(--mono);font-size:9px;letter-spacing:1.5px;text-transform:uppercase;color:var(--steel);}
  .tb-cell .v{font-family:var(--grotesk);font-size:13px;font-weight:600;color:var(--ink);}
  .signout-link{
    font-family:var(--mono);font-size:10px;letter-spacing:1px;text-transform:uppercase;
    color:var(--rust-deep);background:none;border:none;cursor:pointer;padding:0;
    text-decoration:underline;text-decoration-color:rgba(184,80,31,0.4);
  }
  .signout-link:hover{text-decoration-color:var(--rust);}

  @media (max-width:620px){
    .titleblock{grid-template-columns:1fr;}
    .tb-main{border-right:none;border-bottom:1.5px solid var(--ink);}
  }

  /* ================= PANELS ================= */
  .panel{
    background:var(--card);
    border:1.5px solid var(--ink);
    padding:28px;margin-bottom:22px;
    position:relative;
  }
  .panel-head{
    display:flex;justify-content:space-between;align-items:baseline;
    border-bottom:1.5px solid var(--ink);padding-bottom:12px;margin-bottom:20px;
    gap:12px;flex-wrap:wrap;
  }
  .panel-head h2{
    font-family:var(--display);font-weight:700;font-size:18px;letter-spacing:0.3px;margin:0;
  }
  .panel-head .tag-note{font-family:var(--mono);font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--steel);}

  /* ================= GATE / SIGN-IN ================= */
  .gate-wrap{max-width:480px;margin:60px auto 0;}
  .gate-mark{
    width:64px;height:64px;border:2px solid var(--ink);border-radius:50%;
    display:flex;align-items:center;justify-content:center;margin:0 auto 22px;
    position:relative;background:var(--card);
  }
  .gate-mark::before, .gate-mark::after{
    content:"";position:absolute;background:var(--ink);
  }
  .gate-mark::before{width:34px;height:1.5px;top:50%;left:50%;transform:translate(-50%,-50%);}
  .gate-mark::after{width:1.5px;height:34px;top:50%;left:50%;transform:translate(-50%,-50%);}
  .gate-mark .gm-letter{
    position:relative;z-index:2;font-family:var(--mono);font-weight:600;font-size:13px;
    background:var(--card);padding:2px 4px;
  }
  .gate-panel{
    border:1.5px solid var(--ink);background:var(--card);padding:36px 32px;
  }
  .gate-eyebrow{
    font-family:var(--mono);font-size:10px;letter-spacing:3px;text-transform:uppercase;
    color:var(--rust-deep);text-align:center;margin-bottom:10px;
  }
  .gate-title{
    font-family:var(--display);font-weight:700;font-size:24px;text-align:center;margin:0 0 8px;
    line-height:1.15;
  }
  .gate-sub{
    font-family:var(--serif);font-size:14px;color:var(--steel);text-align:center;margin:0 0 26px;
    line-height:1.5;
  }
  label.field{
    display:block;font-family:var(--mono);font-size:10px;letter-spacing:1.5px;text-transform:uppercase;
    color:var(--steel);margin-bottom:6px;
  }
  input[type=text]{
    width:100%;padding:13px 14px;border:1.5px solid var(--ink);
    background:#fff;font-family:var(--grotesk);font-size:15px;color:var(--ink);
  }
  input[type=text]:focus{outline:2px solid var(--rust);outline-offset:1px;}
  input[type=text]::placeholder{color:var(--steel-pale);}

  .role-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:22px;}
  .role-card{
    border:1.5px solid var(--ink);background:var(--paper);padding:20px 14px;
    cursor:pointer;text-align:left;transition:background 0.15s, color 0.15s;
  }
  .role-card .rc-icon{
    width:30px;height:30px;border:1.5px solid currentColor;border-radius:50%;
    display:flex;align-items:center;justify-content:center;margin-bottom:10px;
    font-family:var(--mono);font-size:12px;
  }
  .role-card .rc-title{font-family:var(--grotesk);font-weight:700;font-size:14px;margin-bottom:3px;}
  .role-card .rc-sub{font-family:var(--mono);font-size:10px;color:var(--steel);letter-spacing:0.5px;}
  .role-card:hover{background:var(--ink);color:var(--paper);}
  .role-card:hover .rc-sub{color:var(--steel-pale);}
  .role-card.rust:hover{background:var(--rust-deep);}

  /* ================= BUTTONS ================= */
  .btn{
    font-family:var(--mono);font-size:11px;letter-spacing:1.5px;text-transform:uppercase;
    background:var(--ink);color:var(--paper);border:1.5px solid var(--ink);
    padding:13px 22px;cursor:pointer;transition:background 0.15s, color 0.15s;
  }
  .btn:hover{background:var(--ink-soft);}
  .btn.primary{background:var(--rust-deep);border-color:var(--rust-deep);}
  .btn.primary:hover{background:var(--rust);}
  .btn:disabled{opacity:0.35;cursor:not-allowed;}
  .btn.ghost{background:transparent;color:var(--ink);}
  .btn.ghost:hover{background:var(--ink);color:var(--paper);}
  .btn.small{padding:8px 14px;font-size:10px;}

  /* ================= EXAM CARD (engineer list) ================= */
  .exam-card{
    border:1.5px solid var(--ink);background:var(--paper);
    display:grid;grid-template-columns:1fr auto;gap:20px;
  }
  .ec-main{padding:22px 24px;border-right:1.5px solid var(--ink);}
  .ec-side{padding:22px 24px;display:flex;flex-direction:column;gap:14px;align-items:flex-end;justify-content:center;min-width:190px;}
  .ec-title{font-family:var(--display);font-weight:700;font-size:18px;margin:0 0 8px;}
  .ec-desc{font-family:var(--serif);font-size:13.5px;color:var(--steel);line-height:1.55;margin:0 0 12px;max-width:480px;}
  .ec-meta{font-family:var(--mono);font-size:10.5px;letter-spacing:1px;color:var(--steel);text-transform:uppercase;}
  @media (max-width:620px){
    .exam-card{grid-template-columns:1fr;}
    .ec-main{border-right:none;border-bottom:1.5px solid var(--ink);}
    .ec-side{align-items:flex-start;}
  }

  .status-chip{
    font-family:var(--mono);font-size:9.5px;letter-spacing:1.5px;text-transform:uppercase;
    padding:5px 10px;border:1.5px solid currentColor;white-space:nowrap;
  }
  .status-chip.notstarted{color:var(--steel);}
  .status-chip.inprogress{color:var(--gold);}
  .status-chip.completed{color:var(--pine);}

  /* ================= EXAM TAKING ================= */
  .exam-top{
    display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:18px;gap:16px;flex-wrap:wrap;
  }
  .exam-top h2{font-family:var(--display);font-weight:700;font-size:20px;margin:4px 0 0;}
  .timer{
    font-family:var(--mono);font-size:22px;font-weight:600;letter-spacing:1px;
    background:var(--ink);color:var(--paper);padding:10px 18px;border:1.5px solid var(--ink);
    min-width:96px;text-align:center;
  }
  .timer.low{background:var(--oxide);border-color:var(--oxide);animation:pulse 1s infinite;}
  @keyframes pulse{0%,100%{opacity:1;}50%{opacity:0.65;}}

  .progress-rail{height:6px;background:var(--paper-deep);border:1px solid var(--ink);margin-bottom:22px;overflow:hidden;}
  .progress-fill{height:100%;background:var(--rust);transition:width 0.35s ease;}

  /* section markers — like detail-callout bubbles on a drawing */
  .marker-row{display:flex;gap:7px;flex-wrap:wrap;margin-bottom:24px;}
  .marker{
    width:32px;height:32px;border-radius:50%;border:1.5px solid var(--steel-pale);
    background:#fff;font-family:var(--mono);font-size:11px;font-weight:600;
    display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--steel);
    transition:transform 0.1s;
  }
  .marker:hover{transform:translateY(-2px);}
  .marker.current{border:2px solid var(--ink);color:var(--ink);box-shadow:0 0 0 3px var(--paper-deep);}
  .marker.answered{background:var(--ink);color:var(--paper);border-color:var(--ink);}
  .marker.flagged{box-shadow:0 0 0 2px var(--rust);}

  .q-category{
    font-family:var(--mono);font-size:10px;letter-spacing:2px;text-transform:uppercase;
    color:var(--rust-deep);margin-bottom:10px;
  }
  .q-prompt{
    font-family:var(--serif);font-size:18px;line-height:1.5;margin:0 0 22px;color:var(--ink);
  }
  .q-prompt .qnum{font-family:var(--mono);font-weight:600;color:var(--steel);margin-right:6px;}

  .options{display:flex;flex-direction:column;gap:11px;}
  .option{
    display:grid;grid-template-columns:24px 1fr;gap:13px;align-items:flex-start;
    padding:15px 16px;border:1.5px solid var(--line);background:#fff;cursor:pointer;
    transition:border-color 0.12s, background 0.12s;
  }
  .option:hover{border-color:var(--steel);}
  .option.selected{border-color:var(--ink);background:var(--paper-deep);}
  .opt-radio{
    width:18px;height:18px;border-radius:50%;border:1.5px solid var(--steel-pale);
    margin-top:1px;position:relative;flex-shrink:0;
  }
  .option.selected .opt-radio{border-color:var(--ink);}
  .option.selected .opt-radio::after{
    content:"";position:absolute;inset:3px;border-radius:50%;background:var(--rust-deep);
  }
  .opt-text{font-family:var(--grotesk);font-size:14.5px;line-height:1.5;color:var(--ink);}
  .option input[type=radio]{position:absolute;opacity:0;width:0;height:0;}

  textarea{
    width:100%;min-height:120px;padding:14px;border:1.5px solid var(--ink);
    font-family:var(--grotesk);font-size:14.5px;resize:vertical;background:#fff;line-height:1.55;
  }
  textarea:focus{outline:2px solid var(--rust);outline-offset:1px;}

  .flag-row{display:flex;justify-content:flex-end;margin-top:12px;}
  .flag-btn{
    font-family:var(--mono);font-size:10.5px;letter-spacing:1px;text-transform:uppercase;
    background:none;border:1.5px solid var(--line);color:var(--steel);padding:7px 13px;cursor:pointer;
  }
  .flag-btn.on{background:var(--rust);color:#fff;border-color:var(--rust);}

  .nav-row{display:flex;justify-content:space-between;margin-top:28px;}

  /* ================= RESULTS — section-cut score marker (signature element) ================= */
  .result-hero{display:flex;align-items:center;gap:30px;flex-wrap:wrap;margin-bottom:6px;}
  .cut-marker{
    width:148px;height:148px;border-radius:50%;border:2.5px solid var(--ink);
    position:relative;background:var(--card);flex-shrink:0;
  }
  .cut-marker::before, .cut-marker::after{
    content:"";position:absolute;background:var(--ink);
  }
  .cut-marker::before{width:170px;height:1.5px;top:50%;left:50%;transform:translate(-50%,-50%);}
  .cut-marker::after{width:1.5px;height:170px;top:50%;left:50%;transform:translate(-50%,-50%);}
  .cut-inner{
    position:absolute;inset:10px;border-radius:50%;background:var(--card);
    display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:2;
  }
  .cut-inner .cm-num{font-family:var(--display);font-weight:800;font-size:34px;line-height:1;color:var(--ink);}
  .cut-inner .cm-lbl{font-family:var(--mono);font-size:9px;letter-spacing:1.5px;color:var(--steel);margin-top:5px;text-transform:uppercase;}
  .result-info-title{font-family:var(--display);font-weight:700;font-size:19px;margin:0 0 8px;}
  .result-info-meta{font-family:var(--mono);font-size:11.5px;color:var(--steel);line-height:1.8;}
  .result-info-meta b{color:var(--ink);}

  .breakdown-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:12px;margin-top:22px;}
  .b-row{border:1.5px solid var(--line);background:#fff;padding:13px 14px;}
  .b-row .cat{font-family:var(--mono);font-size:10px;text-transform:uppercase;letter-spacing:1px;color:var(--steel);margin-bottom:6px;}
  .b-row .figs{font-family:var(--grotesk);font-weight:700;font-size:14px;margin-bottom:7px;}
  .b-track{height:5px;background:var(--paper-deep);border:1px solid var(--ink);}
  .b-fill{height:100%;}

  /* ================= ADMIN ================= */
  .stat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:1.5px;margin-bottom:26px;border:1.5px solid var(--ink);background:var(--ink);}
  .stat-cell{background:var(--card);padding:18px 16px;}
  .stat-cell .sc-num{font-family:var(--display);font-weight:800;font-size:30px;color:var(--ink);line-height:1;}
  .stat-cell .sc-lbl{font-family:var(--mono);font-size:9.5px;letter-spacing:1.5px;text-transform:uppercase;color:var(--steel);margin-top:6px;}

  table{width:100%;border-collapse:collapse;font-size:13px;}
  th{
    font-family:var(--mono);font-size:9.5px;letter-spacing:1.5px;text-transform:uppercase;
    text-align:left;border-bottom:1.5px solid var(--ink);padding:10px 12px;color:var(--steel);
  }
  td{border-bottom:1px solid var(--line-soft);padding:13px 12px;vertical-align:middle;}
  tr.clickable{cursor:pointer;transition:background 0.1s;}
  tr.clickable:hover{background:var(--paper-deep);}
  .mini-track{width:74px;height:7px;background:var(--paper-deep);border:1px solid var(--ink);display:inline-block;vertical-align:middle;margin-right:7px;}
  .mini-fill{height:100%;background:var(--rust);display:block;}

  .pill-row{display:flex;gap:7px;margin-bottom:20px;flex-wrap:wrap;}
  .pill{
    font-family:var(--mono);font-size:10.5px;letter-spacing:1px;text-transform:uppercase;
    padding:7px 14px;border:1.5px solid var(--line);background:#fff;cursor:pointer;color:var(--steel);
  }
  .pill.active{background:var(--ink);color:var(--paper);border-color:var(--ink);}

  .backlink{
    font-family:var(--mono);font-size:10.5px;letter-spacing:1px;text-transform:uppercase;
    color:var(--rust-deep);cursor:pointer;background:none;border:none;padding:0;margin-bottom:16px;
    display:inline-flex;align-items:center;gap:6px;
  }
  .backlink:hover{text-decoration:underline;}

  .qstat-row{display:flex;justify-content:space-between;align-items:baseline;padding:11px 0;border-bottom:1px solid var(--line-soft);gap:16px;}
  .qstat-row:last-child{border-bottom:none;}
  .qstat-text{font-family:var(--grotesk);font-size:13px;flex:1;color:var(--ink);}
  .qstat-rate{font-family:var(--mono);font-size:11.5px;white-space:nowrap;font-weight:600;}

  .empty-state{
    font-family:var(--serif);font-size:14px;color:var(--steel);text-align:center;padding:40px 20px;
    border:1.5px dashed var(--line);
  }

  .review-block{border-bottom:1px solid var(--line-soft);padding:16px 0;}
  .review-block:last-child{border-bottom:none;}
  .review-answer{font-family:var(--mono);font-size:12.5px;margin-top:8px;}

  @media (max-width:640px){
    .result-hero{flex-direction:column;align-items:flex-start;}
    .tb-title{font-size:21px;}
  }
</style>
</head>
<body>
<div id="root"></div>

<script>
/* ===================== DATA ===================== */

const QUESTION_BANK = [
  { id:'q1', category:'Structural Loads', type:'mcq',
    prompt:'A reinforced concrete beam is subjected to a uniformly distributed dead load and a live load. Which load combination per typical strength design (LRFD) governs for ultimate strength checks?',
    options:[
      '1.0D + 1.0L',
      '1.2D + 1.6L',
      '0.9D + 1.0W',
      '1.4D only'
    ], correct:1 },
  { id:'q2', category:'Structural Loads', type:'mcq',
    prompt:'For a cantilevered retaining wall, which factor most directly increases the overturning moment about the toe?',
    options:[
      'Increasing the wall footing width',
      'Increasing backfill height behind the wall',
      'Adding a heel extension',
      'Reducing the surcharge load'
    ], correct:1 },
  { id:'q3', category:'Soil & Foundations', type:'mcq',
    prompt:'A geotechnical report shows high plasticity clay (CH) at shallow depth with a high water table. Which foundation strategy is generally LEAST appropriate without further mitigation?',
    options:[
      'Deep pile foundations to competent strata',
      'Shallow spread footings bearing directly on the CH layer',
      'Mat foundation with ground improvement',
      'Soil replacement with engineered fill'
    ], correct:1 },
  { id:'q4', category:'Soil & Foundations', type:'mcq',
    prompt:'During excavation for a foundation, groundwater is encountered above the planned subgrade elevation. What is the most appropriate immediate engineering response?',
    options:[
      'Pour footings directly into standing water to save time',
      'Implement dewatering and verify subgrade bearing capacity before placing concrete',
      'Increase footing depth without re-evaluating bearing capacity',
      'Ignore it if it rains infrequently in the region'
    ], correct:1 },
  { id:'q5', category:'Materials & QA', type:'mcq',
    prompt:'A concrete cylinder break test at 28 days returns results below the specified design strength (f\'c). What is the correct next step per standard QA protocol?',
    options:[
      'Discard the result and assume it was a lab error',
      'Immediately demolish the placed concrete element',
      'Investigate per ACI guidance: review curing, core test if needed, and engage the structural engineer of record',
      'Accept it since most batches pass'
    ], correct:2 },
  { id:'q6', category:'Materials & QA', type:'mcq',
    prompt:'Which condition is the most likely cause of premature corrosion in reinforcing steel within a concrete structure exposed to a marine environment?',
    options:[
      'Excessive concrete cover over rebar',
      'Insufficient concrete cover and chloride ion penetration',
      'Use of epoxy-coated rebar',
      'Low water-cement ratio'
    ], correct:1 },
  { id:'q7', category:'Site Safety', type:'mcq',
    prompt:'Per OSHA excavation standards, at what depth does a trench generally require a protective system (shoring, sloping, or shielding) unless excavated entirely in stable rock?',
    options:[
      '2 feet',
      '5 feet',
      '8 feet',
      '12 feet'
    ], correct:1 },
  { id:'q8', category:'Site Safety', type:'mcq',
    prompt:'A crane lift plan must account for which of the following as a primary safety factor?',
    options:[
      'Only the rated capacity of the crane at maximum boom length',
      'Load weight, lift radius, ground conditions, and wind speed limits',
      'Operator preference only',
      'Time of day only'
    ], correct:1 },
  { id:'q9', category:'Project Management', type:'mcq',
    prompt:'On a critical path schedule, a delay occurs on an activity that has 5 days of float and is NOT on the critical path. What is the most likely impact on the overall project completion date?',
    options:[
      'The project finish date is delayed by the same amount',
      'No impact on project finish date if the delay is within available float',
      'The project automatically finishes earlier',
      'It always triggers a contract claim'
    ], correct:1 },
  { id:'q10', category:'Project Management', type:'mcq',
    prompt:'A change order request comes in mid-construction that affects structural framing already partially installed. What is the correct sequence of action?',
    options:[
      'Proceed with the change immediately to avoid delay',
      'Halt related work, evaluate structural and cost/schedule impact, obtain proper approvals, then proceed',
      'Ignore the request since the framing is already installed',
      'Let the subcontractor decide unilaterally'
    ], correct:1 },
  { id:'q11', category:'Structural Loads', type:'short',
    prompt:'Briefly explain why wind load direction and building geometry both matter when calculating lateral load distribution on a mid-rise structure.',
    rubric:'Look for: wind pressure varies by face/exposure, geometry affects diaphragm/shear wall distribution, asymmetry can cause torsion.' },
  { id:'q12', category:'Soil & Foundations', type:'short',
    prompt:'A site has variable fill material across the footprint of a planned slab-on-grade. Describe your recommended approach before proceeding with construction.',
    rubric:'Look for: geotechnical investigation, proof rolling, possible over-excavation/recompaction, engineer sign-off before pour.' },
  { id:'q13', category:'Site Safety', type:'short',
    prompt:'Describe two engineering controls (not just PPE) that reduce fall hazards on a multi-story steel erection project.',
    rubric:'Look for: guardrails, safety nets, perimeter cables, leading-edge fall protection systems, anchor points — engineering controls rather than PPE alone.' },
];

const CATEGORIES = [...new Set(QUESTION_BANK.map(q=>q.category))];
const EXAM_DURATION_SEC = 30*60; // 30 minutes

const EXAM_DEF = {
  id:'exam-construction-skills-v1',
  title:'Construction Engineering — Internal Skills Evaluation',
  description:'Covers structural loads, soil & foundations, materials QA, site safety, and project management fundamentals. Mixed multiple-choice and short-answer format.',
  questions: QUESTION_BANK
};

/* ===================== STATE (in-memory only) ===================== */

const state = {
  view:'gate',
  currentUser:null,
  submissions:{},
  examProgress:{},
  adminFilter:'all',
  adminDetailUser:null,
};

function render(){ App(document.getElementById('root')); }

/* ===================== HELPERS ===================== */

function formatTime(sec){
  const m = Math.floor(sec/60).toString().padStart(2,'0');
  const s = Math.floor(sec%60).toString().padStart(2,'0');
  return m+':'+s;
}

function todayStamp(){
  const d = new Date();
  return d.toLocaleDateString('en-US', {month:'short', day:'2-digit', year:'numeric'}).toUpperCase();
}

function gradeSubmission(answers){
  let correctCount = 0, mcqTotal = 0;
  const categoryStats = {};
  CATEGORIES.forEach(c=>categoryStats[c]={correct:0,total:0});

  QUESTION_BANK.forEach(q=>{
    if(q.type==='mcq'){
      mcqTotal++;
      categoryStats[q.category].total++;
      const given = answers[q.id];
      if(given!==undefined && Number(given)===q.correct){
        correctCount++;
        categoryStats[q.category].correct++;
      }
    }
  });

  const shortAnswered = QUESTION_BANK.filter(q=>q.type==='short' && answers[q.id] && answers[q.id].trim().length>0).length;
  const shortTotal = QUESTION_BANK.filter(q=>q.type==='short').length;
  const scorePct = mcqTotal>0 ? Math.round((correctCount/mcqTotal)*100) : 0;

  return { correctCount, mcqTotal, scorePct, categoryStats, shortAnswered, shortTotal };
}

function getStatus(userName){
  const sub = state.submissions[userName];
  if(sub) return 'completed';
  const prog = state.examProgress[userName];
  if(prog && Object.keys(prog.answers||{}).length>0) return 'inprogress';
  return 'notstarted';
}

function tierColor(pct){
  return pct>=70 ? 'var(--pine)' : pct>=40 ? 'var(--gold)' : 'var(--oxide)';
}

/* ===================== COMPONENTS ===================== */

function App(root){
  root.innerHTML = '';
  const wrap = document.createElement('div');
  wrap.className='app';

  if(state.view==='gate'){
    wrap.appendChild(Gate());
  } else {
    wrap.appendChild(TitleBlock());
    if(state.view==='engineer-list') wrap.appendChild(EngineerList());
    if(state.view==='exam-taking') wrap.appendChild(ExamTaking());
    if(state.view==='exam-results') wrap.appendChild(ExamResults());
    if(state.view==='admin') wrap.appendChild(AdminDashboard());
  }
  root.appendChild(wrap);
}

function TitleBlock(){
  const tb = document.createElement('div');
  tb.className='titleblock';

  const main = document.createElement('div');
  main.className='tb-main';
  const eyebrow = document.createElement('div');
  eyebrow.className='tb-eyebrow';
  eyebrow.textContent='Site Readiness Program';
  const title = document.createElement('h1');
  title.className='tb-title';
  title.textContent='Engineer Skills Evaluation';
  main.appendChild(eyebrow);
  main.appendChild(title);

  const cells = document.createElement('div');
  cells.className='tb-cells';

  const cell1 = document.createElement('div');
  cell1.className='tb-cell';
  cell1.innerHTML = `<span class="k">Participant</span><span class="v">${state.currentUser ? state.currentUser.name : '—'}</span>`;

  const cell2 = document.createElement('div');
  cell2.className='tb-cell';
  const roleLabel = state.currentUser ? (state.currentUser.role==='admin'?'Administrator':'Engineer') : '—';
  cell2.innerHTML = `<span class="k">Role</span><span class="v">${roleLabel}</span>`;

  const cell3 = document.createElement('div');
  cell3.className='tb-cell';
  const signOut = document.createElement('button');
  signOut.className='signout-link';
  signOut.textContent='Sign out';
  signOut.onclick = ()=>{
    state.currentUser=null;
    state.view='gate';
    render();
  };
  cell3.innerHTML = `<span class="k">Date</span><span class="v">${todayStamp()}</span>`;
  const cell3wrap = document.createElement('div');
  cell3wrap.style.display='flex';
  cell3wrap.style.justifyContent='space-between';
  cell3wrap.style.alignItems='center';
  cell3wrap.style.width='100%';
  cell3wrap.innerHTML = cell3.innerHTML;
  cell3wrap.appendChild(signOut);

  cells.appendChild(cell1);
  cells.appendChild(cell2);
  cells.appendChild(cell3wrap);

  tb.appendChild(main);
  tb.appendChild(cells);
  return tb;
}

function Gate(){
  const wrap = document.createElement('div');
  wrap.className='gate-wrap';

  const mark = document.createElement('div');
  mark.className='gate-mark';
  mark.innerHTML = `<span class="gm-letter">SR</span>`;
  wrap.appendChild(mark);

  const panel = document.createElement('div');
  panel.className='gate-panel';

  const eyebrow = document.createElement('div');
  eyebrow.className='gate-eyebrow';
  eyebrow.textContent='Construction Engineering';
  panel.appendChild(eyebrow);

  const h2 = document.createElement('div');
  h2.className='gate-title';
  h2.textContent='Site Readiness Evaluation';
  panel.appendChild(h2);

  const sub = document.createElement('div');
  sub.className='gate-sub';
  sub.textContent = 'Sign in with your name, then continue as an engineer or an administrator.';
  panel.appendChild(sub);

  const label = document.createElement('label');
  label.className='field';
  label.textContent='Full name';
  panel.appendChild(label);

  const input = document.createElement('input');
  input.type='text';
  input.placeholder='e.g. Sana Tariq';
  input.id='nameInput';
  panel.appendChild(input);

  const roleGrid = document.createElement('div');
  roleGrid.className='role-grid';

  const engCard = document.createElement('div');
  engCard.className='role-card';
  engCard.innerHTML = `<div class="rc-icon">E</div><div class="rc-title">Engineer</div><div class="rc-sub">Take the evaluation</div>`;
  engCard.onclick = ()=>{
    const name = input.value.trim();
    if(!name){ input.style.outline='2px solid var(--oxide)'; input.placeholder='Name required'; return; }
    state.currentUser = {name, role:'engineer'};
    state.view='engineer-list';
    render();
  };

  const adminCard = document.createElement('div');
  adminCard.className='role-card rust';
  adminCard.innerHTML = `<div class="rc-icon">A</div><div class="rc-title">Administrator</div><div class="rc-sub">View progress</div>`;
  adminCard.onclick = ()=>{
    const name = input.value.trim() || 'Admin';
    state.currentUser = {name, role:'admin'};
    state.view='admin';
    render();
  };

  roleGrid.appendChild(engCard);
  roleGrid.appendChild(adminCard);
  panel.appendChild(roleGrid);

  wrap.appendChild(panel);
  return wrap;
}

function EngineerList(){
  const wrap = document.createElement('div');
  const panel = document.createElement('div');
  panel.className='panel';

  const head = document.createElement('div');
  head.className='panel-head';
  head.innerHTML = `<h2>Available Evaluation</h2><span class="tag-note">Sheet 1 of 1</span>`;
  panel.appendChild(head);

  const status = getStatus(state.currentUser.name);

  const card = document.createElement('div');
  card.className='exam-card';

  const left = document.createElement('div');
  left.className='ec-main';
  left.innerHTML = `
    <div class="ec-title">${EXAM_DEF.title}</div>
    <div class="ec-desc">${EXAM_DEF.description}</div>
    <div class="ec-meta">${QUESTION_BANK.length} questions · ${Math.round(EXAM_DURATION_SEC/60)} min limit</div>
  `;

  const right = document.createElement('div');
  right.className='ec-side';

  const tag = document.createElement('span');
  tag.className='status-chip '+status;
  tag.textContent = status==='notstarted'?'Not started':status==='inprogress'?'In progress':'Completed';
  right.appendChild(tag);

  const btn = document.createElement('button');
  btn.className='btn primary';
  if(status==='completed'){
    btn.textContent='View results';
    btn.onclick=()=>{ state.view='exam-results'; render(); };
  } else if(status==='inprogress'){
    btn.textContent='Resume evaluation';
    btn.onclick=()=>{ state.view='exam-taking'; render(); };
  } else {
    btn.textContent='Begin evaluation';
    btn.onclick=()=>{
      state.examProgress[state.currentUser.name] = {
        answers:{}, flagged:[], startedAt:Date.now(), qIndex:0
      };
      state.view='exam-taking';
      render();
    };
  }
  right.appendChild(btn);

  card.appendChild(left);
  card.appendChild(right);
  panel.appendChild(card);
  wrap.appendChild(panel);
  return wrap;
}

let timerInterval = null;

function ExamTaking(){
  const wrap = document.createElement('div');
  const userName = state.currentUser.name;
  const prog = state.examProgress[userName];

  if(!prog){
    state.view='engineer-list';
    render();
    return wrap;
  }

  const elapsed = Math.floor((Date.now()-prog.startedAt)/1000);
  let remaining = EXAM_DURATION_SEC - elapsed;
  if(remaining<=0){
    finishExam(userName);
    return wrap;
  }

  const top = document.createElement('div');
  top.className='exam-top';
  const titleBox=document.createElement('div');
  titleBox.innerHTML = `<div class="tb-eyebrow" style="margin-bottom:2px;">In progress</div><h2>${EXAM_DEF.title}</h2>`;

  const timerBox=document.createElement('div');
  timerBox.className='timer'+(remaining<60?' low':'');
  timerBox.id='timerDisplay';
  timerBox.textContent=formatTime(remaining);

  top.appendChild(titleBox);
  top.appendChild(timerBox);
  wrap.appendChild(top);

  const answeredCount = Object.keys(prog.answers).length;
  const rail=document.createElement('div'); rail.className='progress-rail';
  const fill=document.createElement('div'); fill.className='progress-fill';
  fill.style.width=((answeredCount/QUESTION_BANK.length)*100)+'%';
  rail.appendChild(fill);
  wrap.appendChild(rail);

  const markerRow=document.createElement('div'); markerRow.className='marker-row';
  QUESTION_BANK.forEach((q,i)=>{
    const m=document.createElement('div');
    let cls='marker';
    if(i===prog.qIndex) cls+=' current';
    if(prog.answers[q.id]!==undefined && prog.answers[q.id]!=='') cls+=' answered';
    if(prog.flagged.includes(q.id)) cls+=' flagged';
    m.className=cls;
    m.textContent=i+1;
    m.onclick=()=>{ prog.qIndex=i; render(); };
    markerRow.appendChild(m);
  });
  wrap.appendChild(markerRow);

  const panel=document.createElement('div'); panel.className='panel';
  const q = QUESTION_BANK[prog.qIndex];

  const cat=document.createElement('div'); cat.className='q-category'; cat.textContent=q.category;
  const prompt=document.createElement('div'); prompt.className='q-prompt';
  prompt.innerHTML = `<span class="qnum">${String(prog.qIndex+1).padStart(2,'0')}</span>${q.prompt}`;
  panel.appendChild(cat); panel.appendChild(prompt);

  if(q.type==='mcq'){
    const opts=document.createElement('div'); opts.className='options';
    q.options.forEach((optText,i)=>{
      const opt=document.createElement('label');
      opt.className='option'+(String(prog.answers[q.id])===String(i)?' selected':'');
      const radio=document.createElement('input');
      radio.type='radio'; radio.name='q_'+q.id; radio.value=i;
      radio.checked = String(prog.answers[q.id])===String(i);
      radio.onchange=()=>{ prog.answers[q.id]=i; render(); };
      const dot=document.createElement('div'); dot.className='opt-radio';
      const span=document.createElement('span'); span.className='opt-text'; span.textContent=optText;
      opt.appendChild(radio); opt.appendChild(dot); opt.appendChild(span);
      opts.appendChild(opt);
    });
    panel.appendChild(opts);
  } else {
    const ta=document.createElement('textarea');
    ta.placeholder='Write your response...';
    ta.value = prog.answers[q.id]||'';
    ta.oninput=()=>{ prog.answers[q.id]=ta.value; updateNavOnly(); };
    panel.appendChild(ta);
  }

  const flagRow=document.createElement('div'); flagRow.className='flag-row';
  const flagBtn=document.createElement('button');
  flagBtn.className='flag-btn'+(prog.flagged.includes(q.id)?' on':'');
  flagBtn.textContent = prog.flagged.includes(q.id)?'Flagged for review':'Flag for review';
  flagBtn.onclick=()=>{
    if(prog.flagged.includes(q.id)) prog.flagged=prog.flagged.filter(id=>id!==q.id);
    else prog.flagged.push(q.id);
    render();
  };
  flagRow.appendChild(flagBtn);
  panel.appendChild(flagRow);

  const navRow=document.createElement('div'); navRow.className='nav-row';
  const prevBtn=document.createElement('button'); prevBtn.className='btn ghost';
  prevBtn.textContent='Previous'; prevBtn.disabled = prog.qIndex===0;
  prevBtn.onclick=()=>{ prog.qIndex--; render(); };

  const isLast = prog.qIndex===QUESTION_BANK.length-1;
  const nextBtn=document.createElement('button');
  nextBtn.className='btn '+(isLast?'primary':'');
  nextBtn.textContent = isLast?'Submit evaluation':'Next';
  nextBtn.onclick=()=>{
    if(isLast){
      finishExam(userName);
    } else {
      prog.qIndex++; render();
    }
  };

  navRow.appendChild(prevBtn);
  navRow.appendChild(nextBtn);
  panel.appendChild(navRow);

  wrap.appendChild(panel);

  if(timerInterval) clearInterval(timerInterval);
  timerInterval = setInterval(()=>{
    const el = document.getElementById('timerDisplay');
    if(!el){ clearInterval(timerInterval); return; }
    const newElapsed = Math.floor((Date.now()-prog.startedAt)/1000);
    const newRemaining = EXAM_DURATION_SEC - newElapsed;
    if(newRemaining<=0){
      clearInterval(timerInterval);
      finishExam(userName);
      return;
    }
    el.textContent = formatTime(newRemaining);
    if(newRemaining<60) el.classList.add('low');
  },1000);

  return wrap;
}

function updateNavOnly(){
  const userName = state.currentUser.name;
  const prog = state.examProgress[userName];
  const answeredCount = Object.keys(prog.answers).length;
  const fill = document.querySelector('.progress-fill');
  if(fill) fill.style.width=((answeredCount/QUESTION_BANK.length)*100)+'%';
}

function finishExam(userName){
  if(timerInterval) clearInterval(timerInterval);
  const prog = state.examProgress[userName] || {answers:{}, startedAt:Date.now()};
  const grading = gradeSubmission(prog.answers);
  state.submissions[userName] = {
    userName,
    answers: prog.answers,
    flagged: prog.flagged||[],
    startedAt: prog.startedAt,
    completedAt: Date.now(),
    durationSec: Math.floor((Date.now()-prog.startedAt)/1000),
    ...grading
  };
  state.view='exam-results';
  render();
}

function ExamResults(){
  const wrap=document.createElement('div');
  const sub = state.submissions[state.currentUser.name];

  if(!sub){
    const p=document.createElement('div'); p.className='empty-state';
    p.textContent='No submission found.';
    wrap.appendChild(p);
    return wrap;
  }

  const panel=document.createElement('div'); panel.className='panel';
  const head=document.createElement('div'); head.className='panel-head';
  head.innerHTML = `<h2>Result Detail</h2><span class="tag-note">Evaluation complete</span>`;
  panel.appendChild(head);

  const hero=document.createElement('div'); hero.className='result-hero';
  const cut=document.createElement('div'); cut.className='cut-marker';
  cut.innerHTML = `<div class="cut-inner"><div class="cm-num">${sub.scorePct}%</div><div class="cm-lbl">MCQ Score</div></div>`;
  hero.appendChild(cut);

  const info=document.createElement('div');
  info.innerHTML = `
    <div class="result-info-title">${EXAM_DEF.title}</div>
    <div class="result-info-meta">
      <b>${sub.correctCount}/${sub.mcqTotal}</b> multiple-choice correct<br>
      <b>${sub.shortAnswered}/${sub.shortTotal}</b> short-answer questions completed<br>
      Time used: <b>${formatTime(sub.durationSec)}</b>
    </div>`;
  hero.appendChild(info);
  panel.appendChild(hero);

  const dim = document.createElement('div'); dim.className='dimline';
  dim.innerHTML = `<span>By category</span>`;
  panel.appendChild(dim);

  const breakdown=document.createElement('div'); breakdown.className='breakdown-grid';
  CATEGORIES.forEach(cat=>{
    const cs = sub.categoryStats[cat];
    if(cs.total===0) return;
    const pct = Math.round((cs.correct/cs.total)*100);
    const row=document.createElement('div'); row.className='b-row';
    row.innerHTML = `<div class="cat">${cat}</div>
      <div class="figs">${cs.correct}/${cs.total} <span style="color:var(--steel);font-weight:400;">(${pct}%)</span></div>
      <div class="b-track"><div class="b-fill" style="width:${pct}%;background:${tierColor(pct)}"></div></div>`;
    breakdown.appendChild(row);
  });
  panel.appendChild(breakdown);
  wrap.appendChild(panel);

  const backBtn=document.createElement('button');
  backBtn.className='btn ghost';
  backBtn.textContent='Back to evaluations';
  backBtn.onclick=()=>{ state.view='engineer-list'; render(); };
  wrap.appendChild(backBtn);

  return wrap;
}

/* ===================== ADMIN ===================== */

function getAllParticipants(){
  const names = new Set([...Object.keys(state.submissions), ...Object.keys(state.examProgress)]);
  return [...names];
}

function AdminDashboard(){
  const wrap=document.createElement('div');

  if(state.adminDetailUser){
    wrap.appendChild(AdminUserDetail(state.adminDetailUser));
    return wrap;
  }

  const participants = getAllParticipants();
  const completedSubs = Object.values(state.submissions);
  const total = participants.length;
  const completedCount = completedSubs.length;
  const inProgressCount = participants.filter(n=>getStatus(n)==='inprogress').length;
  const avgScore = completedCount>0 ? Math.round(completedSubs.reduce((a,s)=>a+s.scorePct,0)/completedCount) : 0;

  const panel=document.createElement('div'); panel.className='panel';
  const head=document.createElement('div'); head.className='panel-head';
  head.innerHTML = `<h2>Evaluation Progress — Overview</h2><span class="tag-note">Live</span>`;
  panel.appendChild(head);

  const statGrid=document.createElement('div'); statGrid.className='stat-grid';
  const stats = [
    {num:total, lbl:'Total participants'},
    {num:completedCount, lbl:'Completed'},
    {num:inProgressCount, lbl:'In progress'},
    {num: completedCount>0? avgScore+'%':'—', lbl:'Average score'},
  ];
  stats.forEach(s=>{
    const cell=document.createElement('div'); cell.className='stat-cell';
    cell.innerHTML = `<div class="sc-num">${s.num}</div><div class="sc-lbl">${s.lbl}</div>`;
    statGrid.appendChild(cell);
  });
  panel.appendChild(statGrid);

  if(completedCount>0){
    const dim1=document.createElement('div'); dim1.className='dimline';
    dim1.innerHTML=`<span>Performance by category — all completed</span>`;
    panel.appendChild(dim1);

    const breakdown=document.createElement('div'); breakdown.className='breakdown-grid';
    breakdown.style.marginBottom='10px';
    CATEGORIES.forEach(cat=>{
      let correct=0, total=0;
      completedSubs.forEach(s=>{
        const cs=s.categoryStats[cat];
        if(cs){ correct+=cs.correct; total+=cs.total; }
      });
      if(total===0) return;
      const pct=Math.round((correct/total)*100);
      const row=document.createElement('div'); row.className='b-row';
      row.innerHTML = `<div class="cat">${cat}</div>
        <div class="figs">${correct}/${total} <span style="color:var(--steel);font-weight:400;">(${pct}%)</span></div>
        <div class="b-track"><div class="b-fill" style="width:${pct}%;background:${tierColor(pct)}"></div></div>`;
      breakdown.appendChild(row);
    });
    panel.appendChild(breakdown);

    const dim2=document.createElement('div'); dim2.className='dimline';
    dim2.innerHTML=`<span>Question difficulty — group results</span>`;
    panel.appendChild(dim2);

    const qList=document.createElement('div');
    QUESTION_BANK.filter(q=>q.type==='mcq').forEach(q=>{
      let correct=0;
      completedSubs.forEach(s=>{
        if(s.answers[q.id]!==undefined && Number(s.answers[q.id])===q.correct) correct++;
      });
      const rate = completedCount>0? Math.round((correct/completedCount)*100):0;
      const row=document.createElement('div'); row.className='qstat-row';
      const qText=document.createElement('div'); qText.className='qstat-text';
      qText.textContent = `${q.prompt.length>90? q.prompt.slice(0,90)+'…': q.prompt}`;
      const rateBox=document.createElement('div'); rateBox.className='qstat-rate';
      rateBox.style.color = tierColor(rate);
      rateBox.textContent = `${correct}/${completedCount} (${rate}%)`;
      row.appendChild(qText); row.appendChild(rateBox);
      qList.appendChild(row);
    });
    panel.appendChild(qList);
  }

  wrap.appendChild(panel);

  const tablePanel=document.createElement('div'); tablePanel.className='panel';
  const head2=document.createElement('div'); head2.className='panel-head';
  head2.innerHTML = `<h2>Participants</h2><span class="tag-note">${participants.length} total</span>`;
  tablePanel.appendChild(head2);

  const pillRow=document.createElement('div'); pillRow.className='pill-row';
  ['all','notstarted','inprogress','completed'].forEach(f=>{
    const pill=document.createElement('button');
    pill.className='pill'+(state.adminFilter===f?' active':'');
    pill.textContent = f==='all'?'All':f==='notstarted'?'Not started':f==='inprogress'?'In progress':'Completed';
    pill.onclick=()=>{ state.adminFilter=f; render(); };
    pillRow.appendChild(pill);
  });
  tablePanel.appendChild(pillRow);

  let filtered = participants.filter(n=> state.adminFilter==='all' || getStatus(n)===state.adminFilter);

  if(filtered.length===0){
    const empty=document.createElement('div'); empty.className='empty-state';
    empty.textContent = participants.length===0
      ? 'No engineers have started the evaluation yet.'
      : 'No participants match this filter.';
    tablePanel.appendChild(empty);
  } else {
    const table=document.createElement('table');
    table.innerHTML = `<thead><tr>
      <th>Engineer</th><th>Status</th><th>Score</th><th>Progress</th><th>Time used</th>
    </tr></thead>`;
    const tbody=document.createElement('tbody');

    filtered.sort((a,b)=>a.localeCompare(b));

    filtered.forEach(name=>{
      const status = getStatus(name);
      const sub = state.submissions[name];
      const prog = state.examProgress[name];
      const answeredCount = sub ? QUESTION_BANK.length : (prog? Object.keys(prog.answers).length : 0);
      const pct = Math.round((answeredCount/QUESTION_BANK.length)*100);
      const timeUsed = sub ? formatTime(sub.durationSec) : (prog? formatTime(Math.floor((Date.now()-prog.startedAt)/1000)) : '—');

      const tr=document.createElement('tr');
      tr.className='clickable';
      tr.onclick=()=>{ state.adminDetailUser=name; render(); };

      const tdName=document.createElement('td'); tdName.style.fontWeight='600'; tdName.textContent=name;
      const tdStatus=document.createElement('td');
      tdStatus.innerHTML = `<span class="status-chip ${status}">${status==='notstarted'?'Not started':status==='inprogress'?'In progress':'Completed'}</span>`;
      const tdScore=document.createElement('td');
      tdScore.style.fontFamily='var(--mono)'; tdScore.style.fontWeight='600';
      tdScore.textContent = sub ? sub.scorePct+'%' : '—';
      const tdProgress=document.createElement('td');
      tdProgress.innerHTML = `<span class="mini-track"><span class="mini-fill" style="width:${pct}%;"></span></span><span style="font-family:var(--mono);font-size:11px;">${answeredCount}/${QUESTION_BANK.length}</span>`;
      const tdTime=document.createElement('td');
      tdTime.style.fontFamily='var(--mono)'; tdTime.style.fontSize='12px';
      tdTime.textContent=timeUsed;

      tr.appendChild(tdName); tr.appendChild(tdStatus); tr.appendChild(tdScore); tr.appendChild(tdProgress); tr.appendChild(tdTime);
      tbody.appendChild(tr);
    });
    table.appendChild(tbody);
    tablePanel.appendChild(table);
  }

  wrap.appendChild(tablePanel);
  return wrap;
}

function AdminUserDetail(name){
  const wrap=document.createElement('div');

  const back=document.createElement('button');
  back.className='backlink';
  back.innerHTML = `← Back to all participants`;
  back.onclick=()=>{ state.adminDetailUser=null; render(); };
  wrap.appendChild(back);

  const status = getStatus(name);
  const sub = state.submissions[name];
  const prog = state.examProgress[name];

  const panel=document.createElement('div'); panel.className='panel';
  const head=document.createElement('div'); head.className='panel-head';
  head.innerHTML = `<h2>${name}</h2><span class="status-chip ${status}">${status==='notstarted'?'Not started':status==='inprogress'?'In progress':'Completed'}</span>`;
  panel.appendChild(head);

  if(status==='notstarted'){
    const empty=document.createElement('div'); empty.className='empty-state';
    empty.textContent='This engineer has not started the evaluation.';
    panel.appendChild(empty);
    wrap.appendChild(panel);
    return wrap;
  }

  if(sub){
    const hero=document.createElement('div'); hero.className='result-hero';
    const cut=document.createElement('div'); cut.className='cut-marker';
    cut.style.width='120px'; cut.style.height='120px';
    cut.innerHTML = `<div class="cut-inner"><div class="cm-num" style="font-size:28px;">${sub.scorePct}%</div><div class="cm-lbl">MCQ Score</div></div>`;
    hero.appendChild(cut);
    const info=document.createElement('div');
    info.innerHTML = `<div class="result-info-meta">
      <b>${sub.correctCount}/${sub.mcqTotal}</b> correct (MCQ)<br>
      <b>${sub.shortAnswered}/${sub.shortTotal}</b> short-answer completed<br>
      Time used: <b>${formatTime(sub.durationSec)}</b> &nbsp;·&nbsp; Flagged: <b>${sub.flagged.length}</b>
    </div>`;
    hero.appendChild(info);
    panel.appendChild(hero);

    const dim=document.createElement('div'); dim.className='dimline';
    dim.innerHTML=`<span>By category</span>`;
    panel.appendChild(dim);

    const breakdown=document.createElement('div'); breakdown.className='breakdown-grid';
    CATEGORIES.forEach(cat=>{
      const cs = sub.categoryStats[cat];
      if(cs.total===0) return;
      const pct = Math.round((cs.correct/cs.total)*100);
      const row=document.createElement('div'); row.className='b-row';
      row.innerHTML = `<div class="cat">${cat}</div>
        <div class="figs">${cs.correct}/${cs.total} <span style="color:var(--steel);font-weight:400;">(${pct}%)</span></div>
        <div class="b-track"><div class="b-fill" style="width:${pct}%;background:${tierColor(pct)}"></div></div>`;
      breakdown.appendChild(row);
    });
    panel.appendChild(breakdown);
  } else if(prog){
    const answeredCount = Object.keys(prog.answers).length;
    const p=document.createElement('div'); p.className='result-info-meta'; p.style.marginTop='14px';
    p.innerHTML = `<b>${answeredCount}/${QUESTION_BANK.length}</b> questions answered so far &nbsp;·&nbsp; Time elapsed: <b>${formatTime(Math.floor((Date.now()-prog.startedAt)/1000))}</b>`;
    panel.appendChild(p);
  }

  wrap.appendChild(panel);

  const answersPanel=document.createElement('div'); answersPanel.className='panel';
  const head2=document.createElement('div'); head2.className='panel-head';
  head2.innerHTML = `<h2>Question-by-question review</h2>`;
  answersPanel.appendChild(head2);

  const answers = sub ? sub.answers : prog.answers;

  QUESTION_BANK.forEach((q,i)=>{
    const block=document.createElement('div'); block.className='review-block';

    const cat=document.createElement('div'); cat.className='q-category'; cat.style.marginBottom='6px'; cat.textContent=q.category;
    const prompt=document.createElement('div');
    prompt.style.fontFamily='var(--grotesk)'; prompt.style.fontWeight='600'; prompt.style.fontSize='14px'; prompt.style.color='var(--ink)';
    prompt.textContent=`${String(i+1).padStart(2,'0')}. ${q.prompt}`;
    block.appendChild(cat); block.appendChild(prompt);

    const ans=document.createElement('div'); ans.className='review-answer';

    if(q.type==='mcq'){
      const given = answers[q.id];
      if(given===undefined || given===''){
        ans.style.color='var(--steel)';
        ans.textContent='Not answered';
      } else {
        const isCorrect = Number(given)===q.correct;
        ans.style.color = isCorrect? 'var(--pine)':'var(--oxide)';
        ans.textContent = `Answered: "${q.options[given]}" ${isCorrect?'— Correct':'— Incorrect (correct: "'+q.options[q.correct]+'")'}`;
      }
    } else {
      const given = answers[q.id];
      if(!given || given.trim()===''){
        ans.style.color='var(--steel)';
        ans.textContent='Not answered';
      } else {
        ans.style.color='var(--ink)';
        ans.style.whiteSpace='pre-wrap';
        ans.style.fontFamily='var(--grotesk)';
        ans.textContent = given;
      }
    }
    block.appendChild(ans);
    answersPanel.appendChild(block);
  });

  wrap.appendChild(answersPanel);
  return wrap;
}

/* ===================== INIT ===================== */
render();
</script>
</body>
</html>
